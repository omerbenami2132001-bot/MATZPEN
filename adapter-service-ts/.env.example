# הפורט שהשרת ירוץ עליו
PORT=3000

# הכתובת של ה-API שממנו נשלוף את הקבצים
API_BASE_URL=https://example.com/api

# מפתח ה-API לאימות
API_KEY=
API_NAME=

# הגדרות S3
S3_BUCKET=raw-data
S3_ENDPOINT=https://my-s3.example.com
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# API שמביא metadata נוסף לכל קובץ
METADATA_API_2_URL=https://example.com/api/classification

# Kafka
KAFKA_PRODUCER_BROKERS=kafka.example.com:9092
KAFKA_CERT=/path/to/client.crt
KAFKA_KEY=/path/to/client.key
