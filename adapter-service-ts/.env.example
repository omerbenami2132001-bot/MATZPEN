# Server
PORT=3000

# Source identification
SOURCE_NAME=adapter-service

# External API
API_BASE_URL=https://api.example.com
API_KEY=your-api-key
API_NAME=adapter

# S3
S3_ENDPOINT=https://s3.amazonaws.com
S3_RAW_BUCKET_NAME=raw-data
AWS_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# Kafka
KAFKA_CONSUMER_TOPIC=adapter.file.downloads
KAFKA_PRODUCER_BROKERS_FLIX=kafka:9092
KAFKA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
KAFKA_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Metadata API 2
METADATA_API_2_URL=https://metadata-api-2.example.com
