# Server
PORT=3000

# Source identification
SOURCE_NAME=adapter-service

# External API
API_BASE_URL=https://api.example.com
API_KEY=your-api-key
API_NAME=adapter

# S3
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET_NAME=raw-data
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Kafka
KAFKA_TOPIC=adapter.file.downloads
KAFKA_PRODUCER_BROKERS=kafka:9092
KAFKA_CERT=/path/to/client.crt
KAFKA_KEY=/path/to/client.key

# Metadata API 2
METADATA_API_2_URL=https://metadata-api-2.example.com
